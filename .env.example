# Gora AI Web Platform — Environment Variables
# Copy to .env.local and fill in values

# === Database ===
DB_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgresql://gora:${DB_PASSWORD}@localhost:5432/ondevice_web

# === Site ===
SITE_URL=https://on-device.app
NEXTAUTH_URL=https://on-device.app
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# === Email (Resend) ===
RESEND_API_KEY=re_...
EMAIL_FROM=hello@on-device.app

# === Analytics (Plausible Cloud — free tier) ===
# Sign up at plausible.io, add on-device.app as a site
# No self-hosted infra needed — just a script tag
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=on-device.app

# === Payments — Active ===
# Stripe (Phase 1 — all currencies via card)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...              # One-time price object in Stripe dashboard

# === Payments — Pending Provider Confirmation ===
# IntaSend (M-Pesa / KES) — awaiting contract
INTASEND_PUBLIC_KEY=
INTASEND_SECRET_KEY=
INTASEND_ENV=sandbox                   # sandbox | production

# Flutterwave (M-Pesa / NGN / multi-Africa) — awaiting contract
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# M-Pesa Daraja (direct) — awaiting contract
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://on-device.app/api/webhooks/mpesa
MPESA_ENV=sandbox
# Basic Auth credentials set in Daraja portal for callback verification
# Generate: openssl rand -hex 16
MPESA_CALLBACK_USERNAME=
MPESA_CALLBACK_PASSWORD=

# === App ===
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=ai.gora.ondevice
APK_FILE_PATH=/var/www/downloads/ondevice-ai.apk

# === License System ===
# Signs model download tokens (HMAC-SHA256). Rotate only if compromised.
# Generate: openssl rand -hex 32
LICENSE_HMAC_SECRET=

# === Cloudflare R2 (Model CDN) ===
# Setup: dash.cloudflare.com → R2 → Create bucket "ondevice-models"
# Upload models at: models/lite/model.bin, models/standard/model.bin,
#                   models/multimodal/model.bin, models/max/model.bin
# Create API token with Object Read permission (not full R2 token)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ondevice-models
R2_PUBLIC_DOMAIN=      # e.g. https://models.on-device.org

# === Admin ===
# Protects POST /api/admin/license/revoke
# Generate: openssl rand -hex 24
ADMIN_SECRET=
