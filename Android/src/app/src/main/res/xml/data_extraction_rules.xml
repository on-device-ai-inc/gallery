<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude encrypted OAuth tokens (device-bound key cannot be restored elsewhere) -->
        <exclude domain="sharedpref" path="secure_oauth_tokens.xml"/>
        <!-- Exclude WorkManager database (may contain plaintext access tokens in input data) -->
        <exclude domain="database" path="androidx.work.workdb"/>
        <exclude domain="database" path="androidx.work.workdb-journal"/>
        <exclude domain="database" path="androidx.work.workdb-shm"/>
        <exclude domain="database" path="androidx.work.workdb-wal"/>
        <!-- Exclude Room conversation database (contains user messages and AI responses) -->
        <exclude domain="database" path="ondevice_database"/>
        <exclude domain="database" path="ondevice_database-journal"/>
        <exclude domain="database" path="ondevice_database-shm"/>
        <exclude domain="database" path="ondevice_database-wal"/>
        <!-- Exclude Proto DataStore files (contain user settings, custom instructions, name) -->
        <exclude domain="file" path="datastore/"/>
        <!-- Exclude user conversation media -->
        <exclude domain="file" path="chat_images/"/>
        <exclude domain="file" path="chat_audio/"/>

    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_oauth_tokens.xml"/>
        <exclude domain="database" path="androidx.work.workdb"/>
        <exclude domain="database" path="androidx.work.workdb-journal"/>
        <exclude domain="database" path="androidx.work.workdb-shm"/>
        <exclude domain="database" path="androidx.work.workdb-wal"/>
        <exclude domain="database" path="ondevice_database"/>
        <exclude domain="database" path="ondevice_database-journal"/>
        <exclude domain="database" path="ondevice_database-shm"/>
        <exclude domain="database" path="ondevice_database-wal"/>
        <exclude domain="file" path="datastore/"/>
        <exclude domain="file" path="chat_images/"/>
        <exclude domain="file" path="chat_audio/"/>

    </device-transfer>
</data-extraction-rules>
